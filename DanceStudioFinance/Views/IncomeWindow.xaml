<Window x:Class="VRFinanceApp.Views.IncomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gelir Ekle"
        Height="527"
        Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F5F5" Margin="20">
        <Border Background="White" CornerRadius="10" Padding="20">
            <StackPanel>
                <TextBlock Text="Gelir Ekle"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Branş"/>
                <ComboBox x:Name="cmbBranch"
                          Margin="0,5,0,15"
                          SelectionChanged="cmbBranch_SelectionChanged">
                    <ComboBoxItem Content="K-pop"/>
                    <ComboBoxItem Content="HipHop"/>
                    <ComboBoxItem Content="Salsa"/>
                    <ComboBoxItem Content="Tango"/>
                    <ComboBoxItem Content="Halk Oyunları"/>
                    <ComboBoxItem Content="Oryantal"/>
                    <ComboBoxItem Content="Zumba"/>
                    <ComboBoxItem Content="Bale"/>
                    <ComboBoxItem Content="Modern Dans"/>
                    <ComboBoxItem Content="Jimnastik"/>
                    <ComboBoxItem Content="Resim"/>
                </ComboBox>

                <TextBlock Text="Sınıf Türü"/>
                <ComboBox x:Name="cmbClassType" Margin="0,5,0,15"/>

                <TextBlock Text="Tutar"/>
                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtAmount"
                             Grid.Column="0"
                             PreviewTextInput="txtAmount_PreviewTextInput"/>

                    <TextBlock Grid.Column="1"
                               Text="₺"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="16"/>
                </Grid>

                <TextBlock Text="Tarih"/>
                <DatePicker x:Name="dpDate" Margin="0,5,0,15"/>

                <TextBlock Text="Not"/>
                <TextBox x:Name="txtNote"
                         Margin="0,5,0,20"
                         Height="60"
                         TextWrapping="Wrap"/>

                <Button Content="Kaydet"
                        Height="40"
                        FontSize="16"
                        Click="btnSaveIncome_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>