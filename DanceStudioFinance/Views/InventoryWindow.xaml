<Window x:Class="VRFinanceApp.Views.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Envanter Yönetimi"
        Height="760"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Başlık -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Envanter Yönetimi"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>
                    <TextBlock Text="Ürün ekle, görüntüle ve toplam stok değerini takip et"
                               Margin="0,6,0,0"
                               FontSize="14"
                               Foreground="#6B7280"/>
                </StackPanel>
            </Border>

            <!-- Form -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ürün -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Ürün Adı"/>
                        <TextBox x:Name="txtItemName" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Kategori -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="Kategori"/>
                        <ComboBox x:Name="cmbCategory" Margin="0,5,0,0">
                            <ComboBoxItem Content="Kostüm"/>
                            <ComboBoxItem Content="Ekipman"/>
                            <ComboBoxItem Content="Temizlik"/>
                            <ComboBoxItem Content="Resim Malzemesi"/>
                            <ComboBoxItem Content="Diğer"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Adet -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Adet"/>
                        <TextBox x:Name="txtQuantity"
                                 Margin="0,5,0,0"
                                 PreviewTextInput="OnlyNumber"/>
                    </StackPanel>

                    <!-- Fiyat -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="Birim Fiyat"/>
                        <TextBox x:Name="txtPrice"
                                 Margin="0,5,0,0"
                                 PreviewTextInput="OnlyNumber"/>
                    </StackPanel>

                    <!-- Tarih -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Tarih"/>
                        <DatePicker x:Name="dpDate" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Toplam stok değeri -->
                    <Border Grid.Row="2"
                            Grid.Column="1"
                            Margin="10,20,0,15"
                            Background="#EEF2FF"
                            CornerRadius="12"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Toplam Stok Değeri"
                                       FontSize="13"
                                       Foreground="#4F46E5"/>
                            <TextBlock x:Name="txtTotalInventoryValue"
                                       Text="0 ₺"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#312E81"/>
                        </StackPanel>
                    </Border>

                    <!-- Not -->
                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,15">
                        <TextBlock Text="Not"/>
                        <TextBox x:Name="txtNote"
                                 Margin="0,5,0,0"
                                 Height="70"
                                 TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Buton -->
                    <Button Grid.Row="4"
                            Grid.ColumnSpan="2"
                            Content="Kaydet"
                            Height="42"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Click="btnSave_Click"/>
                </Grid>
            </Border>

            <!-- Liste -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="16"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Envanter Listesi"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Margin="0,0,0,12"/>

                    <DataGrid x:Name="dgInventory"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="White"
                              AlternatingRowBackground="#F8FAFC"
                              BorderThickness="0"
                              MinHeight="260">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ürün"
                                                Binding="{Binding ItemName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Kategori"
                                                Binding="{Binding Category}"
                                                Width="150"/>
                            <DataGridTextColumn Header="Adet"
                                                Binding="{Binding Quantity}"
                                                Width="90"/>
                            <DataGridTextColumn Header="Birim Fiyat"
                                                Binding="{Binding UnitPrice}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Toplam Değer"
                                                Binding="{Binding TotalValue}"
                                                Width="140"/>
                            <DataGridTextColumn Header="Tarih"
                                                Binding="{Binding PurchaseDate}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Not"
                                                Binding="{Binding Note}"
                                                Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>